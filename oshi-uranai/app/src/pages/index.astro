---
const title = "推しの占い子｜働くあなたを推す星読み";
const description = "仕事のこと、自分の価値のこと、人生の転機のこと。生年月日と出生地から、働くあなたに巡ってくる星の流れを読む週報・月報スタイルのパーソナル星読み。怖い予言はありません。";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://2026-cfh.pages.dev/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://2026-cfh.pages.dev/" />
    <meta name="twitter:card" content="summary" />
    <style>
      body {
        font-family: "Hiragino Maru Gothic ProN", "Hiragino Kaku Gothic ProN",
          "Yu Gothic", "Meiryo", sans-serif;
        margin: 0;
        color: #775b90;
        min-height: 100vh;
        background-color: #9ba8ff;
      }
      #bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        display: block;
      }
      main {
        position: relative;
        z-index: 1;
        max-width: 620px;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 4rem;
        text-align: center;
      }
      h1 {
        margin: 0;
      }
      h1 img {
        width: min(280px, 70vw);
        height: auto;
        filter: drop-shadow(0 1px 6px rgba(255, 255, 255, 0.35));
      }
      .tagline {
        margin: 0.8rem 0 0;
        font-size: 1rem;
        letter-spacing: 0.3em;
        color: #fff;
      }
      .portrait {
        width: 180px;
        height: 180px;
        margin: 2.2rem auto 0;
        display: block;
        border-radius: 50%;
        box-shadow: 0 6px 24px rgba(119, 91, 144, 0.25);
      }
      .lead {
        font-size: 0.95rem;
        line-height: 2.2;
        letter-spacing: 0.12em;
        color: #fff;
        text-shadow: 0 1px 4px rgba(80, 70, 160, 0.25);
        margin: 2.2rem 0 2.5rem;
      }
      .cta {
        display: inline-block;
        padding: 0.95rem 2.6rem;
        background: #7c4fc4;
        color: #fff;
        border-radius: 999px;
        text-decoration: none;
        font-size: 1.05rem;
        font-weight: bold;
        letter-spacing: 0.1em;
        box-shadow: 0 4px 14px rgba(124, 79, 196, 0.35);
      }
      .cta:hover {
        background: #6c41af;
      }
      .assure {
        margin: 1.2rem 0 0;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.85);
      }
      .sub {
        margin-top: 1.8rem;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
      }
      .sub a {
        color: #fff;
      }
      .copyright {
        margin: 3rem 0 0;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.75);
      }
    </style>
  </head>
  <body>
    <canvas id="bg" aria-hidden="true"></canvas>
    <main>
      <h1>
        <img src="/logo.png" alt="推しの占い子" width="787" height="243" />
      </h1>
      <p class="tagline">働くあなたを推す星読み</p>
      <img
        class="portrait"
        src="/uranaiko.png"
        alt="占い子のイラスト"
        width="800"
        height="800"
      />
      <p class="lead">
        このまま今の仕事でいいのかな。<br />
        わたしの価値って、なんだろう。<br />
        そんな迷いごと、星に読ませてください。<br />
        生まれた瞬間の星の配置から、いまのあなたに巡る流れを読んで、<br />
        攻める日も、休む日も、ぜんぶ含めてあなたを推します。
      </p>
      <a class="cta" href="/reading">星を読んでもらう</a>
      <p class="assure">怖い予言や、スピリチュアルすぎる言葉は使いません。</p>
      <p class="sub"><a href="/about">この占いについて</a></p>
      <p class="copyright">&copy; 2026 推しの占い子</p>
    </main>
    <script>
      const canvas = document.getElementById("bg") as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      let w = 0;
      let h = 0;
      let dpr = 1;

      function resize() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = window.innerWidth;
        h = window.innerHeight;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      resize();
      window.addEventListener("resize", () => {
        resize();
        if (reduceMotion) draw(12);
      });

      // ゆっくり漂う光のブロブ（Apple風の柔らかい面）
      const blobs = [
        { c: "255,255,255", a: 0.22, r: 0.5, x: 0.2, y: 0.15, sx: 0.9, sy: 0.6, p: 0.0 },
        { c: "236,150,255", a: 0.4, r: 0.5, x: 0.85, y: 0.3, sx: 0.7, sy: 0.9, p: 2.1 },
        { c: "64,150,255", a: 0.45, r: 0.6, x: 0.35, y: 0.9, sx: 1.1, sy: 0.5, p: 4.2 },
        { c: "255,255,255", a: 0.18, r: 0.45, x: 0.7, y: 0.7, sx: 0.6, sy: 0.8, p: 1.3 },
      ];

      function draw(t: number) {
        ctx.clearRect(0, 0, w, h);

        const grad = ctx.createLinearGradient(0, 0, w, h * 0.35);
        grad.addColorStop(0, "#4fb2fb");
        grad.addColorStop(0.5, "#9ba8ff");
        grad.addColorStop(1, "#dba5ff");
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, w, h);

        const base = Math.max(w, h);
        for (const b of blobs) {
          const bx = (b.x + Math.sin(t * 0.06 * b.sx + b.p) * 0.13) * w;
          const by = (b.y + Math.cos(t * 0.05 * b.sy + b.p) * 0.11) * h;
          const br = b.r * base * (1 + Math.sin(t * 0.04 + b.p) * 0.08);
          const g = ctx.createRadialGradient(bx, by, 0, bx, by, br);
          g.addColorStop(0, `rgba(${b.c},${b.a})`);
          g.addColorStop(1, `rgba(${b.c},0)`);
          ctx.fillStyle = g;
          ctx.fillRect(0, 0, w, h);
        }

        // 幾何学的な波ライン（うねりながら流れる等間隔の曲線群）
        const lines = 14;
        const gap = h / (lines + 1);
        for (let i = 0; i < lines; i++) {
          const baseY = gap * (i + 1);
          const amp = gap * (0.55 + 0.35 * Math.sin(i * 1.7 + t * 0.1));
          const k = 0.0035 + 0.0011 * Math.sin(i * 2.3);
          const speed = 0.18 + 0.05 * ((i * 7) % 3);
          const isPurple = i % 3 === 2;
          ctx.beginPath();
          for (let x = -10; x <= w + 10; x += 6) {
            const y =
              baseY +
              Math.sin(x * k + t * speed + i * 1.1) * amp +
              Math.sin(x * k * 2.6 - t * speed * 0.7 + i) * amp * 0.3;
            if (x === -10) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.strokeStyle = isPurple
            ? "rgba(60,90,220,0.12)"
            : "rgba(255,255,255,0.30)";
          ctx.lineWidth = 1.4;
          ctx.stroke();
        }
      }

      if (reduceMotion) {
        draw(12);
      } else {
        const start = performance.now();
        function loop(now: number) {
          draw((now - start) / 1000);
          requestAnimationFrame(loop);
        }
        requestAnimationFrame(loop);
      }
    </script>
  </body>
</html>
